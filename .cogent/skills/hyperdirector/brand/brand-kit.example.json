    "trial": "Start your free trial"
  },
  "assets": {
    "logo": "brand/assets/logo.png",
    "watermark": "brand/assets/watermark.png",
    "background_default": "brand/assets/bg-default.jpg",
    "music_default": "brand/assets/music-default.mp3"
  },
  "safe_zone": {
    "top_percent": 10,
    "bottom_percent": 22,
