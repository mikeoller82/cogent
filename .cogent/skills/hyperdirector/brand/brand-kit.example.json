    "ui_copy_language": "zh-CN",
    "technical_terms": "keep_english_with_chinese_explanation"
  },
  "colors": {
    "primary": "#111827",
    "accent": "#6366F1",
    "background": "#FFFFFF",
    "text_primary": "#1F2937",
    "text_secondary": "#6B7280"
  },
  "fonts": {
    "headline": "Inter",
    "body": "Noto Sans SC",
    "code": "JetBrains Mono"
  },
  "motion_language": {
